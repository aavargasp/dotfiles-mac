# Basic replacements
alias ls 'eza --icons=auto'
alias ll 'eza -lh --icons=auto'
alias la 'eza -lha --icons=auto'

# Tree view
alias lt 'eza --tree --icons=auto'
alias lt2 'eza --tree --level=2 --icons=auto'
alias lt3 'eza --tree --level=3 --icons=auto'

# With git status (great inside repos)
alias lg 'eza -lh --git --icons=auto'

# Directories only
alias ld 'eza -lhD --icons=auto'
