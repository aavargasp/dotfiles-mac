### GitHub Config ###
# Personal account
Host github.com
    HostName ssh.github.com
    User git
    Port 443
    PreferredAuthentications publickey
	
# Work account
Host ssh.dev.azure.com
    User git
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/ssh-work-esmax.pub
    IdentitiesOnly yes
    WarnWeakCrypto no

### GitLab Config ###
# Personal account
Host gitlab.com
    HostName altssh.gitlab.com
    User git
    Port 443
    PreferredAuthentications publickey

